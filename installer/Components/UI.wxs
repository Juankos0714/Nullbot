<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>

    <ComponentGroup Id="UiComponents" Directory="INSTALLFOLDER">

      <!-- Main WPF executable -->
      <Component Id="CmpNullBotExe" Guid="D9E0F1A2-B3C4-5678-2345-678900000008">
        <File Id="FileNullBotExe"
              Source="ui_publish\NullBot.exe"
              KeyPath="yes"/>
      </Component>

    </ComponentGroup>

    <!-- Start Menu + Desktop shortcuts -->
    <ComponentGroup Id="ShortcutComponents">

      <Component Id="CmpStartMenuShortcut"
                 Directory="ApplicationProgramsFolder"
                 Guid="A2B3C4D5-E6F7-8901-5678-900000000011">
        <Shortcut Id="StartMenuShortcut"
                  Name="NullBot"
                  Description="Open Source Anti-Botnet for Windows 11"
                  Target="[INSTALLFOLDER]NullBot.exe"
                  WorkingDirectory="INSTALLFOLDER"/>
        <RemoveFolder Id="CleanupStartMenu" Directory="ApplicationProgramsFolder" On="uninstall"/>
        <RegistryValue Root="HKCU"
                       Key="Software\NullBot"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes"/>
      </Component>

    </ComponentGroup>

  </Fragment>
</Wix>
