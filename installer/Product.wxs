<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="NullBot"
           Manufacturer="NullBot Contributors"
           Version="0.1.0"
           UpgradeCode="A9B8C7D6-E5F4-4321-8765-0987654321BA"
           Language="1033"
           Compressed="yes">

    <SummaryInformation Description="NullBot — Open Source Anti-Botnet for Windows 11"
                        Keywords="security antivirus botnet"/>

    <!-- Prevent downgrades -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed. Uninstall it first."/>

    <!-- Single embedded CAB -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <!-- ═══════════════════ Directories ═══════════════════ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NullBot"/>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="DATAROOTDIR" Name="NullBot">
        <Directory Id="SIGSDIR"    Name="signatures">
          <Directory Id="UPDATERDIR" Name="updater"/>
        </Directory>
        <Directory Id="QUARDIR"    Name="quarantine"/>
        <Directory Id="LOGSDIR"    Name="logs"/>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="NullBot"/>
    </StandardDirectory>

    <!-- ═══════════════════ Features ═══════════════════ -->

    <!-- Core (required) -->
    <Feature Id="CoreFeature" Title="Core Engine" Description="Scanner, heuristics, and quarantine engine."
             Level="1" Absent="disallow" AllowAdvertise="no">
      <ComponentGroupRef Id="CoreComponents"/>
      <ComponentGroupRef Id="DataDirComponents"/>
      <ComponentGroupRef Id="SignaturesComponents"/>
    </Feature>

    <!-- Desktop UI -->
    <Feature Id="UiFeature" Title="Desktop UI" Description="WPF dashboard application."
             Level="1">
      <ComponentGroupRef Id="UiComponents"/>
      <ComponentGroupRef Id="ShortcutComponents"/>
    </Feature>

    <!-- AMSI real-time protection -->
    <Feature Id="AmsiFeature"
             Title="Real-time Protection"
             Description="Registers NullBot as a Windows AMSI provider to scan scripts in real time."
             Level="1">
      <ComponentGroupRef Id="AmsiComponents"/>
    </Feature>

    <!-- Auto-updater -->
    <Feature Id="UpdaterFeature"
             Title="Auto-update Signatures"
             Description="Runs update_feeds.py every 6 hours via Windows Task Scheduler. Requires Python 3.11+ on PATH."
             Level="1">
      <ComponentGroupRef Id="UpdaterComponents"/>
    </Feature>

    <!-- Context menu (optional, off by default) -->
    <Feature Id="ContextMenuFeature"
             Title="Windows Context Menu"
             Description="Adds 'Scan with NullBot' to the right-click menu for files."
             Level="0">
      <ComponentGroupRef Id="ContextMenuComponents"/>
    </Feature>

    <!-- ═══════════════════ Custom action: AMSI register ═══════════════════ -->
    <CustomAction Id="RegisterAmsi"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no"
                  ExeCommand="regsvr32.exe /s &quot;[INSTALLFOLDER]nullbot_amsi_provider.dll&quot;"
                  Directory="System64Folder"/>

    <CustomAction Id="UnregisterAmsi"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no"
                  ExeCommand="regsvr32.exe /u /s &quot;[INSTALLFOLDER]nullbot_amsi_provider.dll&quot;"
                  Directory="System64Folder"/>

    <!-- Custom action: install scheduled task -->
    <CustomAction Id="InstallScheduler"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no"
                  ExeCommand="powershell.exe -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]scripts\install_scheduler.ps1&quot;"
                  Directory="INSTALLFOLDER"/>

    <!-- Custom action: remove scheduled task on uninstall -->
    <CustomAction Id="RemoveScheduler"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no"
                  ExeCommand="powershell.exe -Command &quot;Unregister-ScheduledTask -TaskName 'NullBot Signature Updater' -Confirm:$false -ErrorAction SilentlyContinue&quot;"
                  Directory="INSTALLFOLDER"/>

    <!-- Kill running processes before uninstall -->
    <CustomAction Id="KillNullBot"
                  Execute="immediate"
                  Return="ignore"
                  ExeCommand="taskkill.exe /F /IM NullBot.exe /IM nullbot_cli.exe 2&gt;nul"
                  Directory="System64Folder"/>

    <!-- ═══════════════════ Sequences ═══════════════════ -->
    <InstallExecuteSequence>
      <!-- Register AMSI after files are installed, only on fresh install/upgrade -->
      <Custom Action="RegisterAmsi" After="InstallFiles">
        <![CDATA[NOT REMOVE AND (REINSTALL OR NOT Installed) AND &AmsiFeature=3]]>
      </Custom>

      <!-- Install scheduler after files land, only if feature selected -->
      <Custom Action="InstallScheduler" After="RegisterAmsi">
        <![CDATA[NOT REMOVE AND (REINSTALL OR NOT Installed) AND &UpdaterFeature=3]]>
      </Custom>

      <!-- On uninstall: kill processes, unregister AMSI, remove task -->
      <Custom Action="KillNullBot" Before="RemoveFiles">
        <![CDATA[REMOVE="ALL"]]>
      </Custom>
      <Custom Action="UnregisterAmsi" After="KillNullBot">
        <![CDATA[REMOVE="ALL"]]>
      </Custom>
      <Custom Action="RemoveScheduler" After="UnregisterAmsi">
        <![CDATA[REMOVE="ALL"]]>
      </Custom>
    </InstallExecuteSequence>

    <!-- ═══════════════════ UI ═══════════════════ -->
    <ui:WixUI Id="WixUI_NullBot"/>

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf"/>
    <WixVariable Id="WixUIBannerBmp"  Value="UI\Assets\banner.png"/>
    <WixVariable Id="WixUIDialogBmp"  Value="UI\Assets\dialog.png"/>

    <!-- Finish actions -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch NullBot now"/>
    <CustomAction Id="LaunchNullBot"
                  Execute="immediate"
                  Return="asyncNoWait"
                  ExeCommand="[INSTALLFOLDER]NullBot.exe"
                  Directory="INSTALLFOLDER"/>

  </Package>
</Wix>
