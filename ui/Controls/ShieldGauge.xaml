<UserControl x:Class="NullBot.UI.Controls.ShieldGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="200" Height="200">

    <Grid>
        <!-- Background track ring -->
        <Ellipse Width="160" Height="160"
                 Stroke="#1E2A38" StrokeThickness="10"
                 Fill="Transparent"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>

        <!-- Glow ring (animated opacity, same geometry as arc path) -->
        <Path x:Name="GlowPath"
              StrokeThickness="16"
              Fill="Transparent"
              Opacity="0.3"/>

        <!-- Progress arc (updated from code-behind on status change) -->
        <Path x:Name="ArcPath"
              StrokeThickness="10"
              Fill="Transparent"
              StrokeLineJoin="Round"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"/>

        <!-- Shield icon (Lucide Shield path, scaled via Viewbox) -->
        <Viewbox Width="64" Height="64"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Canvas Width="24" Height="24">
                <Path x:Name="ShieldIcon"
                      Data="M12,22 C12,22 4,18 4,12 L4,5 L12,2 L20,5 L20,12 C20,18 12,22 12,22 Z"
                      StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"/>
            </Canvas>
        </Viewbox>

        <!-- Status label -->
        <TextBlock x:Name="StatusLabel"
                   Text="PROTECTED"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="9"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,54,0,0"
                   CharacterSpacing="200"/>
    </Grid>
</UserControl>
