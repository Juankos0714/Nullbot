<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- === Background layers === -->
    <Color x:Key="BackgroundColor">#FF0A0C0F</Color>
    <Color x:Key="PanelColor">#FF141A22</Color>
    <Color x:Key="SurfaceColor">#FF0D1219</Color>
    <Color x:Key="SidebarActiveColor">#FF1A2435</Color>
    <Color x:Key="SidebarHoverColor">#FF121820</Color>
    <Color x:Key="BorderColor">#FF1E2A38</Color>
    <Color x:Key="InputBackgroundColor">#FF0D1219</Color>

    <!-- === Accent === -->
    <Color x:Key="AccentColor">#FF00D4FF</Color>
    <Color x:Key="AccentHoverColor">#FF33DFFF</Color>
    <Color x:Key="AccentPressedColor">#FF00A8CC</Color>

    <!-- === Semantic status === -->
    <Color x:Key="SafeColor">#FF00C896</Color>
    <Color x:Key="WarningColor">#FFF5A623</Color>
    <Color x:Key="DangerColor">#FFFF3B5C</Color>

    <!-- === Text === -->
    <Color x:Key="TextPrimaryColor">#FFE8EEF5</Color>
    <Color x:Key="TextSecondaryColor">#FF7A90A8</Color>
    <Color x:Key="TextDisabledColor">#FF3A4A5C</Color>

    <!-- ============================================================ -->
    <!-- SolidColorBrushes (use these in XAML, not raw colors)        -->
    <!-- ============================================================ -->

    <SolidColorBrush x:Key="BackgroundBrush"      Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="PanelBrush"           Color="{StaticResource PanelColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"         Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"   Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"    Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush"          Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"         Color="{StaticResource InputBackgroundColor}"/>

    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"     Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush"   Color="{StaticResource AccentPressedColor}"/>

    <SolidColorBrush x:Key="SafeBrush"            Color="{StaticResource SafeColor}"/>
    <SolidColorBrush x:Key="WarningBrush"         Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"          Color="{StaticResource DangerColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"     Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"   Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush"    Color="{StaticResource TextDisabledColor}"/>

    <!-- Transparent accent for glow effects -->
    <SolidColorBrush x:Key="AccentGlowBrush"      Color="#2200D4FF"/>
    <SolidColorBrush x:Key="SafeGlowBrush"        Color="#2200C896"/>
    <SolidColorBrush x:Key="DangerGlowBrush"      Color="#22FF3B5C"/>

</ResourceDictionary>
