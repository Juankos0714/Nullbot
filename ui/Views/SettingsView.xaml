<UserControl x:Class="NullBot.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NullBot.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource HeadlineStyle}" Margin="0,0,0,24"/>

            <!-- Behaviour -->
            <TextBlock Text="BEHAVIOUR" Style="{StaticResource LabelStyle}" Margin="0,0,0,12"/>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Auto-update interval -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-update interval"
                                       Style="{StaticResource BodyStyle}" FontWeight="SemiBold"/>
                            <TextBlock Text="How often to pull fresh threat feeds"
                                       Style="{StaticResource CaptionStyle}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding UpdateIntervalOptions}"
                                  SelectedItem="{Binding UpdateIntervalHours}"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}Every {0}h}"
                                               FontFamily="{StaticResource BodyFont}" FontSize="13"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Separator Margin="0,0,0,16"/>

                    <!-- Auto-quarantine -->
                    <CheckBox Content="Auto-quarantine on detection"
                              IsChecked="{Binding AutoQuarantineEnabled}"
                              Style="{StaticResource ToggleSwitchStyle}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource BodyFont}"
                              FontSize="13"
                              Margin="0,0,0,16"/>

                    <!-- Run at startup -->
                    <CheckBox Content="Run at Windows startup"
                              IsChecked="{Binding RunAtStartup}"
                              Style="{StaticResource ToggleSwitchStyle}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontFamily="{StaticResource BodyFont}"
                              FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Excluded paths -->
            <TextBlock Text="EXCLUDED PATHS" Style="{StaticResource LabelStyle}" Margin="0,0,0,12"/>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="24,16" Margin="0,0,0,20">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding ExcludedPaths}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}"
                                               Style="{StaticResource MonoStyle}"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Remove"
                                            Style="{StaticResource DangerButtonStyle}"
                                            FontSize="11" Padding="8,4"
                                            Command="{Binding DataContext.RemoveExcludedPathCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewExcludedPath, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Add"
                                Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding AddExcludedPathCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About -->
            <TextBlock Text="ABOUT" Style="{StaticResource LabelStyle}" Margin="0,0,0,12"/>
            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="24,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="NullBot v"
                                   Style="{StaticResource BodyStyle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   Style="{StaticResource MonoStyle}" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Open Source Anti-Botnet for Windows 11"
                               Style="{StaticResource BodyStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="License: GPL-3.0"
                               Style="{StaticResource CaptionStyle}" Margin="0,0,0,16"/>
                    <Button Content="View on GitHub"
                            Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding OpenGitHubCommand}"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
